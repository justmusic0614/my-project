{
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(node --check:*)",
      "Bash(npm:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git config:*)",
      "Bash(git check-ignore:*)",
      "Bash(git remote:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(chmod:*)",
      "Bash(./scripts/*:*)",
      "Bash(bash tools/*:*)",
      "Bash(python3:*)",
      "Bash(ps:*)",
      "Bash(lsof:*)",
      "Bash(pkill:*)",
      "Bash(tee:*)",
      "Bash(wc:*)",
      "Bash(gh:*)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '今天是 '$(date +%Y-%m-%d)'. 回覆請使用繁體中文.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/suweicheng/projects/my-project/.claude/hooks/review_plan_loop.py"
          }
        ]
      }
    ]
  }
}
