{
  "name": "social-digest",
  "version": "1.0.0",
  "description": "Facebook Groups 晨報 Agent — IMAP 收信 + AI 摘要 + Email Digest",

  "imap": {
    "host": "imap.gmail.com",
    "port": 993,
    "secure": true,
    "user": "${GMAIL_IMAP_USER}",
    "password": "${GMAIL_IMAP_PASSWORD}",
    "mailboxType": "gmail_label",
    "label": "${IMAP_LABEL:-FB-Groups}",
    "feedbackLabel": "${IMAP_FEEDBACK_LABEL:-FB-Groups-Feedback}",
    "lookbackMinutes": 120,
    "connectionTimeout": 15000
  },

  "smtp": {
    "host": "smtp.gmail.com",
    "port": 587,
    "secure": false,
    "user": "${GMAIL_SMTP_USER}",
    "password": "${GMAIL_SMTP_PASSWORD}",
    "from": "${GMAIL_SMTP_USER}",
    "recipient": "${DIGEST_RECIPIENT}"
  },

  "ai": {
    "enabled": "${AI_ENABLED:-true}",
    "provider": "openai",
    "model": "gpt-4o-mini",
    "apiKey": "${OPENAI_API_KEY}",
    "maxPostsPerDay": 200,
    "maxBatches": 6,
    "batchSize": 30,
    "promptVersion": "1.0"
  },

  "digest": {
    "topPicksMax": 20,
    "everythingElseMax": 60,
    "subjectPrefix": "[SocialDigest]",
    "sendDryRunHtml": true,
    "topPicksCapPerSource": 3
  },

  "http": {
    "connectTimeout": 5000,
    "readTimeout": 15000,
    "maxResponseSize": 2097152,
    "userAgent": "social-digest/1.0",
    "concurrency": 3
  },

  "collectors": {
    "l1_imap": { "enabled": true },
    "hackernews": { "enabled": true, "maxItems": 30, "safetyWindowMinutes": 180 },
    "rss": { "enabled": true, "maxItemsPerFeed": 5, "maxAgeHours": 336, "safetyWindowMinutes": 180, "concurrency": 3 },
    "github_releases": { "enabled": true, "token": "${GITHUB_TOKEN:-}", "maxReleasesPerRepo": 3, "safetyWindowMinutes": 180 },
    "github_trending": { "enabled": false, "token": "${GITHUB_TOKEN:-}", "minStars": 50, "createdWithinDays": 7 }
  },

  "tracking": {
    "enabled": false,
    "host": "${REDIRECT_HOST:-localhost}",
    "redirectBaseUrl": "${REDIRECT_BASE_URL:-}"
  },

  "db": {
    "path": "${DB_PATH:-data/social-digest.db}"
  },

  "paths": {
    "src": "src",
    "data": "data",
    "runtime": "data/runtime",
    "logs": "logs"
  },

  "logging": {
    "level": "${LOG_LEVEL:-info}",
    "format": "${LOG_FORMAT:-pretty}"
  }
}
